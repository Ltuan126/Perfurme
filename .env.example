# Server
PORT=5000
NODE_ENV=development

# MongoDB (replace with your MongoDB Atlas URI for production)
MONGO_URI=mongodb://localhost:27017/perfume

# JWT Secret (change this in production!)
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=15m

# Auth rate limiting
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_LOGIN_MAX=10
AUTH_RATE_LIMIT_REGISTER_MAX=5

# CORS (set to your frontend domain in production)
CORS_ORIGIN=*

# Payment Gateway - Momo (test mode)
MOMO_PARTNER_CODE=MOMOXXXXXX
MOMO_ACCESS_KEY=access_key_test
MOMO_SECRET_KEY=secret_key_test
MOMO_ENDPOINT=https://test-payment.momo.vn/gw_payment/transactionProcessor
MOMO_RETURN_URL=http://localhost:3000/payment/callback
MOMO_IPN_URL=http://localhost:5000/api/payment/callback?method=momo

# Payment Gateway - VNPay (test mode)
VNPAY_TMN_CODE=TMNCODE0000
VNPAY_HASH_SECRET=hash_secret_test
VNPAY_ENDPOINT=https://sandbox.vnpayment.vn/paymentv2/Transaction/BillDetail
VNPAY_RETURN_URL=http://localhost:3000/payment/callback
